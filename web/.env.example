# Copy this file to `.env.local` and fill in the values.
# `.env.local` is git-ignored so your secrets never get committed.

# Supabase project URL (safe to expose - shipped to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://yrpjtaqdwieavlhathvo.supabase.co

# Supabase publishable / anon key (safe to expose - shipped to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_tVIYXFaEoPU8ghYK-fePEg_RzDxrMIM

# Supabase service_role key (SECRET - server-side only, never expose to the browser).
# Required by /api/orders and the image upload script.
# Get it from Supabase -> Project Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Order confirmation emails (Resend - https://resend.com)
# Without these, orders still work but no email is sent.
RESEND_API_KEY=your-resend-api-key
# Example: Chosen by Chloe <orders@chosenbychloe.com>
# For testing before your domain is verified, Resend may allow:
# Chosen by Chloe <onboarding@resend.dev>
ORDER_EMAIL_FROM=Chosen by Chloe <onboarding@resend.dev>
# CC on every customer order confirmation (comma-separated for multiple)
ORDER_EMAIL_CC=dongchen@chosenbychloe.com
